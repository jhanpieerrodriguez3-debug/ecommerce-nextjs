# ============================================================
# apps/bff — .env.example
# ============================================================
# Copia este archivo a .env.local para desarrollo local.
# En producción, configura estas variables en Vercel Dashboard.
# ============================================================

# Supabase — Backend (sin prefijo NEXT_PUBLIC_)
SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# URL del users-service (en desarrollo: http://localhost:5000)
USERS_SERVICE_URL=https://tu-users-service.vercel.app

# CORS — URL del frontend Next.js deployado
FRONTEND_URL=https://tu-web.vercel.app

# Runtime
NODE_ENV=development
PORT=4000
