# ============================================================
# apps/users-service — .env.example
# ============================================================
# Copia este archivo a .env.local para desarrollo local.
# En producción, configura estas variables en Vercel Dashboard.
#
# Generar JWT_SECRET seguro:
#   openssl rand -base64 64
#   o: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
# ============================================================

# JWT — Secret criptográficamente fuerte (mínimo 64 caracteres)
JWT_SECRET=GENERA_UN_SECRET_SEGURO_CON_OPENSSL_RAND_BASE64_64

# CORS — URLs de los servicios que pueden llamar a este servicio
FRONTEND_URL=https://tu-web.vercel.app
BFF_URL=https://tu-bff.vercel.app

# Runtime
NODE_ENV=development
PORT=5000
